# AWS credentials are read by the AWS SDK default credential chain.
# Prefer one of these methods:
# 1) export AWS_PROFILE=your-profile
# 2) export AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN

# ===== Required AWS + KMS settings =====
AWS_REGION=us-east-1
KMS_KEY_ID=alias/blockchain-wallet-key
# Optional, used for documentation/troubleshooting only
KMS_KEY_ARN=

# ===== API server settings =====
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001
SESSION_SECRET=replace-with-long-random-string

# ===== Backward-compatible aliases (if you copied old env files) =====
# If you have legacy variable names, map them like this:
# WALLET_AWS_REGION -> AWS_REGION
# WALLET_KMS_KEY_ID -> KMS_KEY_ID
# WALLET_KMS_ARN    -> KMS_KEY_ARN
