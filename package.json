{
  "name": "kms-wallet-enterprise",
  "version": "1.0.0",
  "description": "Enterprise Wallet Management with AWS KMS and Vault",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "server": "node dist/api/server.js",
    "server:dev": "nodemon src/api/server.ts",
    "demo": "ts-node src/demo/FullDemo.ts",
    "demo:quick": "ts-node src/demo/QuickDemo.ts",
    "demo:login": "ts-node src/demo/LoginDemo.ts",
    "setup": "chmod +x scripts/setup-aws.sh && ./scripts/setup-aws.sh",
    "clean": "rm -rf dist node_modules logs",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "test": "echo \"No tests specified\" && exit 0",
    "prebuild": "npm run clean",
    "postinstall": "echo \"✅ Dependencies installed successfully\""
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.525.0",
    "@aws-sdk/client-secrets-manager": "^3.525.0",
    "@aws-sdk/credential-providers": "^3.525.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "ethers": "^6.10.0",
    "express": "^4.18.2",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "keywords": ["aws", "kms", "vault", "wallet", "blockchain", "encryption"],
  "author": "",
  "license": "ISC"
}