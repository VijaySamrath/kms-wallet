{
  "name": "kms-wallet-enterprise",
  "version": "1.0.0",
  "description": "Enterprise Wallet Management with AWS KMS and Vault",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.ts",
    "dev": "nodemon src/index.ts",
    "server": "node dist/api/server.js",
    "server:dev": "nodemon src/api/server.ts",
    "demo": "ts-node src/demo/FullDemo.ts",
    "setup": "chmod +x scripts/setup-aws.sh && ./scripts/setup-aws.sh",
    "clean": "rm -rf dist logs",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "test": "echo \"No tests specified\" && exit 0",
    "prebuild": "npm run clean",
    "postinstall": "echo \"✅ Dependencies installed successfully\"",
    "demo:full": "ts-node src/demo/FullDemo.ts",
    "check": "tsc --noEmit",
    "compile": "hardhat compile",
    "deploy": "hardhat run scripts/deploy-contract.ts --network sepolia",
    "deploy:local": "hardhat run scripts/deploy-contract.ts --network hardhat"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.525.0",
    "@aws-sdk/client-secrets-manager": "^3.525.0",
    "@aws-sdk/credential-providers": "^3.525.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-waffle": "^2.0.6",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "chai": "^6.2.2",
    "eslint": "^8.0.0",
    "ethereum-waffle": "^4.0.10",
    "ethers": "^6.16.0",
    "hardhat": "^3.1.12",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "aws",
    "kms",
    "vault",
    "wallet",
    "blockchain",
    "encryption"
  ],
  "author": "",
  "license": "ISC"
}
